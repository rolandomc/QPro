# ── Supabase ───────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Mercado Pago ───────────────────────────────────────────
EXPO_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxxxxxx

# ── SPEI / apiCEP ──────────────────────────────────────────
# Tu API key de https://www.apicep.cloud
EXPO_PUBLIC_APICEP_API_KEY=apicep_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CLABE donde recibes las transferencias
EXPO_PUBLIC_CLABE_DESTINO=000000000000000000

# Nombre del banco mostrado al usuario en la pantalla SPEI
EXPO_PUBLIC_BANCO_NOMBRE=BBVA / STP
